@model IEnumerable<StoreProductListDto>

@{
    ViewData["Title"] = "Store Products";
}
<h2>Mağaza Ürünleri</h2>
<a class="btn btn-primary" asp-action="Create">Yeni Ürün Ekle</a>
<hr />
<table class="table table-striped table-bordered my-5">
    <thead>
        <tr>
            <th>Ürün Adı</th>
            <th>Fiyat</th>
            <th>Stok</th>
            <th>Durum</th>
            <th style="width:16rem">işlemler</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Price.ToString("C2")</td>
                    <td>@item.Stock</td>
                    <td>
                        @if (item.Active)
                        {
                            <span class="text-success fw-bold">Satışta</span>
                        }
                        else
                        {
                            <span class="text-dark">Satışda Değil</span>
                        }
                    </td>
                    <td>
                        <div class="btn-group">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Düzenle</a>
                            <a asp-action="Images" asp-route-id="@item.Id" class="btn btn-sm btn-info">Görseller</a>
                            <a asp-action="Features" asp-route-id="@item.Id" class="btn btn-sm btn-info">Özellikler</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Sil</a>
                        </div>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5">
                    <h5 class="text-center text-muted">Kayıtlı ürün bulunamadı!</h5>
                </td>
            </tr>
        }
    </tbody>
</table>
