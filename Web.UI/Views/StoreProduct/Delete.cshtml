@model Core.Concretes.DTOs.Product.UpdateProductDto

@{
    ViewData["Title"] = "Delete Product";
}

<h1>Delete Product</h1>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <input asp-for="Id" type="hidden" />

    <div class="form-group">
        <label asp-for="Name" class="control-label"></label>
        <input asp-for="Name" class="form-control" readonly />
    </div>

    <div class="form-group">
        <label asp-for="Description" class="control-label"></label>
        <textarea asp-for="Description" class="form-control" readonly></textarea>
    </div>

    <div class="form-group">
        <label asp-for="Price" class="control-label"></label>
        <input asp-for="Price" class="form-control" type="number" readonly />
    </div>

    <div class="form-group">
        <label asp-for="Stock" class="control-label"></label>
        <input asp-for="Stock" class="form-control" readonly />
    </div>

    <div class="form-group">
        <label asp-for="SKU" class="control-label"></label>
        <input asp-for="SKU" class="form-control" readonly />
    </div>

    <div class="form-group">
        <label asp-for="BrandId" class="control-label"></label>
        <select asp-for="BrandId" class="form-control" asp-items="ViewBag.Brands" disabled>
            <option value="">-- Select Brand --</option>
        </select>
    </div>

    <div class="form-group">
        <label asp-for="CategoryId" class="control-label"></label>
        <select asp-for="CategoryId" class="form-control" asp-items="ViewBag.Categories" disabled>
            <option value="">-- Select Category --</option>
        </select>
    </div>

    <div class="form-group form-check mt-2">
        <input asp-for="Active" class="form-check-input" disabled />
        <label asp-for="Active" class="form-check-label"></label>
    </div>

    <div class="form-group mt-3">
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</form>

@section Scripts {

}
