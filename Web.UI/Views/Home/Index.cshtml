@model MallHomeDto
@{
    ViewData["Title"] = "E-AVM 597";
}

<div class="row row-cols-1 row-cols-sm-2 row-cols-md-4 row-cols-lg-6 g-3 my-5">
    @if (Model.ActiveStores != null && Model.ActiveStores.Any())
    {
        foreach (var store in Model.ActiveStores)
        {
            <div class="col">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title text-center">@store.StoreName</h5>
                    </div>
                </div>
            </div>
        }
    }
</div>

<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 row-cols-xl-5 g-3 my-5">
    @if (Model.FeaturedProducts != null && Model.FeaturedProducts.Any())
    {
        foreach (var product in Model.FeaturedProducts)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    @if (!string.IsNullOrEmpty(product.MainImageUrl))
                    {
                        <img src="@product.MainImageUrl" class="card-img-top p-2" alt="@product.Name" style="height:15rem; object-fit:contain;" />
                    }
                    else
                    {
                        <div class="bg-light text-muted text-center d-flex align-items-center justify-content-center" style="height:15rem;">
                            Görsel Yok!
                        </div>
                    }
                    <div class="card-body d-flex flex-column">
                        <p class="text-muted small mb-1 fw-bold">@product.StoreName</p>
                        <h6 class="card-title text-truncate" title="@product.Name">@product.Name</h6>
                        <h5 class="text-danger mt-auto mb-0">@product.Price.ToString("C2")</h5>
                    </div>
                    <div class="card-footer bg-white border-top-0 pt-0">
                        <a href="#" class="btn btn-info w-100 btn-sm">İncele</a>
                    </div>
                </div>
            </div>
        }
    }
</div>